{
  "name": "logic-generator",
  "private": true,
  "version": "0.1.6",
  "type": "module",
  "description": "Compile a formula into an Approximately Up in-game logic blueprint (.bp/.bpmeta/.bpex ZIP) with a live circuit visualization.",
  "scripts": {
